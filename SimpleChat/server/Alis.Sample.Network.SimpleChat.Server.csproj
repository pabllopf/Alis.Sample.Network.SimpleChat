<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>

        <Configurations>Debug;Release</Configurations>
        <Platforms>AnyCPU;x64;arm64;x86;WebAssembly</Platforms>
        <NoAutoGenerateFiles>true</NoAutoGenerateFiles>
        <RuntimeIdentifier>osx-arm64</RuntimeIdentifier>
    </PropertyGroup>
    
    <!-- Configuración Debug -->
    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|WebAssembly'">
        <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
    </PropertyGroup>

    <!-- Configuración Release -->
    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|WebAssembly'">
        <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
    </PropertyGroup>


    <ItemGroup>
        <PackageReference Include="Alis.Extension.Network" Version="*" />
        <PackageReference Include="Alis" Version="*" />
    </ItemGroup>
    
</Project>
